# Safe defaults for a brand-new local Windows demo machine.
# You can copy this file to `.env` and run the project immediately.
# The default path is:
# - local OCR on http://127.0.0.1:8001
# - local MySQL in Docker
# - local Mailpit for email preview
# - Dify / Feishu / real SMTP are optional and disabled by default

# ------------------------------
# MySQL
# ------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=invoice_app
MYSQL_PASSWORD=invoice_app_password
MYSQL_DB=enterprise_ai
MYSQL_ROOT_PASSWORD=root123456

# ------------------------------
# OCR
# ------------------------------
OCR_BASE_URL=http://127.0.0.1:8001
OCR_RETRY_MAX=5
OCR_RETRY_SLEEP_SEC=2.0

# ------------------------------
# Local invoice files
# ------------------------------
INVOICES_DIR=./invoices
PO_NO=PO-DEMO-001

# ------------------------------
# Dify (optional)
# Leave blank if you only want local OCR fallback.
# ------------------------------
DIFY_API_KEY=
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_IMAGE_KEY=invoice
DIFY_WORKFLOW_ID=
DIFY_RETRY_MAX=3
DIFY_RETRY_SLEEP_SEC=2.0

# ------------------------------
# Feishu Bitable (optional)
# Leave blank unless you want MySQL -> Feishu sync.
# ------------------------------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=
FEISHU_SYNC_MODE=off
FEISHU_RETRY_WORKER_ENABLED=False
FEISHU_RETRY_INTERVAL_SEC=300
FEISHU_RETRY_MODE=failed
FEISHU_RETRY_BATCH_LIMIT=20

# ------------------------------
# Email
# Local default uses Mailpit, so no SMTP auth is required.
# If you switch to a real SMTP provider, fill SMTP_USER / SMTP_PASS
# and update SMTP_HOST / SMTP_PORT / TLS settings.
# ------------------------------
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=AI Invoice Audit Assistant
SMTP_FROM_EMAIL=noreply@invoice-audit.local
ALERT_FALLBACK_TO=finance-demo@local.test
DEMO_LEADER_EMAIL=
SMTP_USE_TLS=False
SMTP_USE_SSL=False

# ------------------------------
# Streamlit UI and local tools
# ------------------------------
UI_PORT=8517
ANOMALY_FORM_BASE_URL=http://127.0.0.1:8517/?view=anomaly_form
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
