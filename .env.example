# App
APP_NAME=Invoice Audit Platform
APP_ENV=local
APP_SECRET_KEY=change-me-in-production
APP_API_HOST=0.0.0.0
APP_API_PORT=8080
APP_API_BASE_URL=http://127.0.0.1:8080
APP_WORKER_ID=worker-1
TASK_POLL_INTERVAL_SEC=2
TASK_RETRY_LIMIT=3
AUTH_SESSION_TTL_HOURS=12
AUTO_REVIEW_CONFIDENCE_THRESHOLD=0.85
APP_STORAGE_DIR=storage

# Seed users
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=admin123456
APP_OPERATOR_USERNAME=operator
APP_OPERATOR_PASSWORD=operator123456
APP_REVIEWER_USERNAME=reviewer
APP_REVIEWER_PASSWORD=reviewer123456

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=invoice_app
MYSQL_PASSWORD=invoice_app_password
MYSQL_DB=enterprise_ai
MYSQL_ROOT_PASSWORD=root123456

# OCR
OCR_BASE_URL=http://127.0.0.1:8000
OCR_RETRY_MAX=5
OCR_RETRY_SLEEP_SEC=2.0

# Dify (optional)
DIFY_API_KEY=
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_IMAGE_KEY=invoice
DIFY_WORKFLOW_ID=
DIFY_RETRY_MAX=3
DIFY_RETRY_SLEEP_SEC=2.0

# Feishu (optional)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=
FEISHU_SYNC_MODE=off

# Email
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=AI Invoice Audit Assistant
SMTP_FROM_EMAIL=noreply@invoice-audit.local
ALERT_FALLBACK_TO=finance-demo@local.test
SMTP_USE_TLS=False
SMTP_USE_SSL=False

# UI
UI_PORT=8517
ANOMALY_FORM_BASE_URL=http://127.0.0.1:8517/?view=review
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
